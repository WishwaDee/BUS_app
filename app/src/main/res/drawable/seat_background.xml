<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/seat_selected" />
            <corners android:radius="8dp" />
            <stroke android:width="2dp" android:color="@color/accent_color" />
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/seat_booked" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="@color/error_color" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/seat_available" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="@color/success_color" />
        </shape>
    </item>
</selector>